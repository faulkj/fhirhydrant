# Derives FHIR server → <base>/api/FHIR/<version> and token → <base>/oauth2/token
FHIR_BASE_URL=https://fhir.example.org
FHIR_CLIENT_ID=your-client-id


# Base64-encoded RSA PKCS#8 private key (kid derived automatically via JWK Thumbprint)
# Generate: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 | openssl base64 -A
# PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("key.pem"))
FHIR_ACTIVE_KEY=LS0tLS1CRUdJTi...base64-of-your-pem...

# Optional retired keys for JWKS rotation (base64 of concatenated PEMs)
# FHIR_RETIRED_KEYS=LS0tLS1CRUdJTi...base64-of-concatenated-pems...

# ── Optional ─────────────────────────────────────────────────────────────────

# Enables terminology_lookup and code_search tools (HL7 public server needs no auth)
FHIR_TERMINOLOGY_BASE_URL=https://tx.fhir.org/r4

# Omit to enable the built-in /jwks endpoint; set to use an external JWKS URL
# FHIR_JWKS_URL=

# FHIR version: R4+ (default R4)
# FHIR_VERSION=R4

# Override derived FHIR API + token URLs for non-standard server layouts
# FHIR_SERVER_URL=https://fhir.example.org/fhir/R4
# FHIR_TOKEN_URL=https://auth.example.org/token

# Additional path prefixes allowed in pagination links
# FHIR_PAGINATION_PATHS=FHIRProxy

# "http" (default) or "stdio"
# MCP_TRANSPORT=http
# PORT=5000
# BIND_HOST=127.0.0.1

# Comma-separated hostnames for DNS rebinding protection (required when 0.0.0.0)
# ALLOWED_HOSTS=your-app.azurecontainerapps.io

# /metadata mismatch handling: "strict" | "warn" | "off"
# FHIR_METADATA_MODE=strict

# FHIR_DEFAULT_COUNT=0          # Default _count injected when resource advertises it (0 = server decides)
# FHIR_MAX_COUNT=0              # Cap on caller _count values (0 = no cap)

# Response shape: "compact" | "full" | "compact-locked" (hides responseMode from AI)
# FHIR_RESPONSE_MODE=compact

# FHIR_MAX_RESPONSE_BYTES=262144 # Byte limit on tool responses; chunked when exceeded
# FHIR_REQUEST_TIMEOUT_MS=30000 # Per-attempt timeout (ms) for outgoing FHIR requests

# Comma-separated: create, update, patch, delete. Unset = read-only.
# Further gated by /metadata — only advertised interactions are exposed.
# FHIR_WRITE_CAPABILITIES=create,update,patch,delete

# Write-payload validation: off, local, or server. Default = local.
# local = client-side structural checks before sending (no network cost).
# server = local + a server $validate preflight for create/update before the write.
# FHIR_VALIDATE_WRITES=local

# Comma-separated Bundle types: batch, transaction. Unset = bundle tool disabled.
# FHIR_BUNDLE_CAPABILITIES=batch
# Set to true to allow write entries inside Bundles (also requires FHIR_WRITE_CAPABILITIES).
# FHIR_BUNDLE_WRITES_ENABLED=false

# Comma-separated operation catalog keys (e.g. everything,lastn). Leading $ optional.
# Set to "none" to disable all operations. Unset = all catalog ops enabled.
# FHIR_OPERATIONS=everything,lastn,validate,docref,expand,lookup,translate,summary,match

# Comma-separated sinks: "console", "file", or both. Off when unset.
# FHIR_AUDIT_SINK=console,file
# FHIR_AUDIT_FILE=./audit.jsonl # JSONL destination (parent dir must exist)

# Auth-proxy header whose value becomes "user" in audit events
# FHIR_AUDIT_USER_HEADER=X-MS-CLIENT-PRINCIPAL-NAME

# Log verbosity: error | warn | info (default) | debug
# LOG_LEVEL=info
