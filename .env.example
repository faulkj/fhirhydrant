# Required
FHIR_BASE_URL=https://fhir.example.org
# Derives: FHIR server  → <base>/api/FHIR/R4
#          Token endpoint → <base>/oauth2/token
FHIR_CLIENT_ID=your-client-id

# Private keys — comma-separated PEM file paths (relative to cwd or absolute)
# kid is derived from each filename: private-<kid>.pem → kid "<kid>"
# Generate with: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out private-20260610.pem
FHIR_PRIVATE_KEY=private-20260610.pem

# Active signing key — which kid to use for signing JWT assertions
# Must match a kid derived from one of the PEM filenames above
FHIR_ACTIVE_KEY=20260610

# JWKS — choose one:
# Option 1: Omit FHIR_JWKS_URL to enable the built-in /jwks endpoint.
#           Register https://<your-host>/jwks with your FHIR authorization server.
# Option 2: Set FHIR_JWKS_URL to an externally hosted JWKS (e.g. GitHub Gist).
#           The built-in /jwks endpoint is disabled when this is set.
FHIR_JWKS_URL=

# Optional URL Overrides
# Override the derived FHIR API + token URLs for non-standard server layouts
# When set, these take precedence over values derived from FHIR_BASE_URL
# FHIR_SERVER_URL=https://fhir.example.org/fhir/R4
# FHIR_TOKEN_URL=https://auth.example.org/token

# Pagination path aliases — comma-separated path prefixes allowed in pagination URLs
# The configured FHIR server path is always allowed; add aliases for servers that
# return pagination links with a different proxy prefix (e.g. Epic's /FHIRProxy)
# FHIR_PAGINATION_PATHS=/FHIRProxy/api/FHIR/R4/

# Transport
# MCP transport mode: "http" (default) or "stdio"
# MCP_TRANSPORT=http
# PORT=5000
# BIND_HOST=127.0.0.1

# HTTP Security
# Comma-separated hostnames for DNS rebinding protection (required when binding 0.0.0.0)
# ALLOWED_HOSTS=your-app.azurecontainerapps.io

# Metadata & Response Shaping
# How to handle /metadata mismatches: "strict" blocks unadvertised params, "warn" allows with warning, "off" skips all checks
# FHIR_METADATA_MODE=strict
# Default _count injected into searches when the resource advertises _count in /metadata
# FHIR_DEFAULT_COUNT=20
# Maximum _count allowed — caller-supplied values above this are capped
# FHIR_MAX_COUNT=100
# Universal byte limit on tool responses — returns an error instead of the payload when exceeded
# FHIR_MAX_RESPONSE_BYTES=65536

# Audit Sink
# Comma-separated audit sinks: "console", "file", or both. Off when unset/empty.
# Console emits [audit] JSON lines alongside existing [fhir] logs.
# FHIR_AUDIT_SINK=console,file
# File appends JSONL to FHIR_AUDIT_FILE (parent directory must exist).
# FHIR_AUDIT_FILE=./audit.jsonl
# HTTP header injected by your auth proxy whose value appears as "user" in audit events. Ignored when unset.
# Common values: X-MS-CLIENT-PRINCIPAL-NAME (Azure EasyAuth), X-Auth-Request-Email (OAuth2 Proxy)
# FHIR_AUDIT_USER_HEADER=X-MS-CLIENT-PRINCIPAL-NAME

# Debugging
# Enable verbose FHIR request logging (includes query params — may contain PHI)
# DEBUG=true
